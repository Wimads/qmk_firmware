{
    "keyboard_name": "argos mouse (working title)",
    "url": "https://bastardkb.com/argos"
    "usb": {
        "device_version": "2.0.0",
        "pid": "0x1838"
    },
    "matrix_pins": {
        "direct": [
            ["GP8", "GP7"],
            ["GP9", "GP6"],
        ],
    },
    "diode_direction": "ROW2COL",
    "processor": "RP2040",
    "bootloader": "rp2040",
    "layouts": {
        "LAYOUT": {
            "layout": [
                {"matrix": [0, 0], "x": 0, "y": 0},
                {"matrix": [0, 1], "x": 1, "y": 0},

                {"matrix": [1, 0], "x": 0, "y": 1},
                {"matrix": [1, 1], "x": 1, "y": 1}
            ]
        }
    },
    "features": {
        "bootmagic": true,
        "mousekey": true,
        "rgb_matrix": true,
        "pointing_device": true
    }
}
